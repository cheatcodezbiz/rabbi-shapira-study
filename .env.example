# Copy to .env (or .env.local) for local development with `vercel dev`.
# Never commit your real key.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-2.5-flash-preview-tts.
# As of May 2026 the 3.1 preview blocks neutral Chinese narration as
# PROHIBITED_CONTENT and ignores safetySettings — switch back when fixed:
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
